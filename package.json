{
  "name": "meetingbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Dockerized meeting bot control plane with OpenUtter integration and avatar architecture planning.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
